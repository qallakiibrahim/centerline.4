rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default-deny Catch-all Security Gateway
    match /{document=**} {
      allow read, write: if false;
    }

    // Main App State syncer collection rules
    match /app_state/{documentId} {
      allow read: if isSignedIn() && isVerified();
      
      allow create, update: if isSignedIn() && isVerified()
        && isValidId(documentId)
        && isValidAppState(incoming())
        && (
          // Super admins får ALLTID skriva ALT (Ibrahim eller registrerad super_admin)
          isSuperAdmin()
          // connection_test_placeholder får skrivas av alla för att testa uppkoppling
          || (documentId == 'connection_test_placeholder')
          // history can be written by anyone
          || (documentId == 'history')
          // user_roles kan BARA skrivas av super_admin
          || (documentId == 'user_roles' && isSuperAdmin())
          // other configs can be written by process engineer or higher
          || (documentId != 'user_roles' && documentId != 'history' && isProcessEngineerOrHigher())
        );
      
      allow delete: if false; // Deny state deletion entirely to prevent data loss
    }

    // Standalone Helper functions
    function isValidId(id) {
      return id == 'points' 
        || id == 'layout' 
        || id == 'layouts' 
        || id == 'definitions' 
        || id == 'recipes' 
        || id == 'hierarchy' 
        || id == 'backgrounds' 
        || id == 'history'
        || id == 'user_roles'
        || id == 'connection_test_placeholder';
    }

    function incoming() {
      return request.resource.data;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return request.auth.token.email_verified == true;
    }

    // Säkerställer att auth-token faktiskt har en e-post innan vi gör toLowerCase()
    function hasEmail(email) {
      return request.auth.token.keys().hasAll(['email']) && request.auth.token.email.toLowerCase() == email.toLowerCase();
    }

    // Hjälpfunktion för att hämta rollen på ett säkert sätt - med fallback om dokumentet inte finns
    function getUserRole() {
      let emailKey = request.auth.token.email.toLowerCase();
      // Använd exists() för att säkert kontrollera om dokumentet finns innan vi läser det
      return exists(/databases/$(database)/documents/app_state/user_roles) 
        ? get(/databases/$(database)/documents/app_state/user_roles).data.value[emailKey]
        : null;
    }

    function isSuperAdmin() {
      return isSignedIn() && isVerified() && (
        // Ibrahim är alltid super_admin
        hasEmail('qallakiibrahim@gmail.com')
        // Andra användare måste vara registrerade i user_roles
        || getUserRole() == 'super_admin'
      );
    }

    function isProcessEngineerOrHigher() {
      return isSignedIn() && isVerified() && (
        hasEmail('qallakiibrahim@gmail.com')
        || (
          exists(/databases/$(database)/documents/app_state/user_roles)
          && (
            getUserRole() == 'super_admin'
            || getUserRole() == 'line_leader'
            || getUserRole() == 'process_engineer'
          )
        )
      );
    }

    function isValidAppState(data) {
      return data.keys().hasAll(['key', 'value']) 
        && data.key is string 
        && data.value != null;
    }
  }
}
