rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default-deny Catch-all Security Gateway
    match /{document=**} {
      allow read, write: if false;
    }

    // Main App State syncer collection rules
    match /app_state/{documentId} {
      allow read: if isSignedIn() && isVerified();
      
      allow create, update: if isSignedIn() && isVerified()
        && isValidId(documentId)
        && isValidAppState(incoming())
        && (
          // user_roles can only be written by super_admin
          (documentId == 'user_roles' && isSuperAdmin())
          // history can be written by anyone
          || (documentId == 'history')
          // other configs can be written by process engineer or higher
          || (documentId != 'user_roles' && documentId != 'history' && isProcessEngineerOrHigher())
        );
      
      allow delete: if false; // Deny state deletion entirely to prevent data loss
    }

    // Standalone Helper functions
    function isValidId(id) {
      return id == 'points' 
        || id == 'layout' 
        || id == 'definitions' 
        || id == 'recipes' 
        || id == 'hierarchy' 
        || id == 'backgrounds' 
        || id == 'history'
        || id == 'user_roles';
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      // Mandating email verification for live write stability
      return request.auth.token.email_verified == true;
    }

    function isSuperAdmin() {
      return isSignedIn() && isVerified() && (
        request.auth.token.email.lower() == 'qallakiibrahim@gmail.com'
        || (
          exists(/databases/$(database)/documents/app_state/user_roles)
          && get(/databases/$(database)/documents/app_state/user_roles).data.value[request.auth.token.email.lower()] == 'super_admin'
        )
      );
    }

    function isProcessEngineerOrHigher() {
      return isSignedIn() && isVerified() && (
        request.auth.token.email.lower() == 'qallakiibrahim@gmail.com'
        || (
          exists(/databases/$(database)/documents/app_state/user_roles)
          && (
            get(/databases/$(database)/documents/app_state/user_roles).data.value[request.auth.token.email.lower()] == 'super_admin'
            || get(/databases/$(database)/documents/app_state/user_roles).data.value[request.auth.token.email.lower()] == 'line_leader'
            || get(/databases/$(database)/documents/app_state/user_roles).data.value[request.auth.token.email.lower()] == 'process_engineer'
          )
        )
      );
    }

    function isValidAppState(data) {
      return data.keys().hasAll(['key', 'value']) 
        && data.keys().size() == 2 
        && data.key is string 
        && data.value != null;
    }
  }
}
