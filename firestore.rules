rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default-deny Catch-all Security Gateway
    match /{document=**} {
      allow read, write: if false;
    }

    // App State
    match /app_state/{documentId} {
      allow read: if isSignedIn() && isVerified();
      
      allow create, update: if isSignedIn() && isVerified()
        && isValidId(documentId)
        && isValidAppState(incoming())
        && (
          // Super Admin får ALLTID skriva ALT
          isSuperAdmin()
          // history får skrivas av ALLA (Registrera mätvärden)
          || documentId == 'history'
          // connection_test får skrivas av alla
          || documentId == 'connection_test_placeholder'
          // user_roles får bara skrivas av Super Admin
          || (documentId == 'user_roles' && isSuperAdmin())
          // Layout, definitions, recipes, hierarchy, backgrounds får skrivas av PE+
          || (
            (documentId == 'layout' || documentId == 'layouts' || documentId == 'definitions' 
             || documentId == 'recipes' || documentId == 'hierarchy' || documentId == 'backgrounds')
            && isProcessEngineerOrHigher()
          )
          // points får skrivas av PE+ (flytta punkter & ändra sektioner)
          || (documentId == 'points' && isProcessEngineerOrHigher())
        );
      
      allow delete: if false;
    }

    function isValidId(id) {
      return id == 'points' || id == 'layout' || id == 'layouts' || id == 'definitions' 
        || id == 'recipes' || id == 'hierarchy' || id == 'backgrounds' || id == 'history'
        || id == 'user_roles' || id == 'connection_test_placeholder';
    }

    function incoming() { return request.resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return request.auth.token.email_verified == true; }
    
    function isIbrahim() {
      return isSignedIn() && isVerified() && request.auth.token.keys().hasAll(['email']) && request.auth.token.email == 'qallakiibrahim@gmail.com';
    }

    function getUserRole() {
      return (!isSignedIn() || !isVerified() || !request.auth.token.keys().hasAll(['email']))
        ? null
        : (!exists(/databases/$(database)/documents/app_state/user_roles)
          ? null
          : (request.auth.token.email in get(/databases/$(database)/documents/app_state/user_roles).data.value
            ? get(/databases/$(database)/documents/app_state/user_roles).data.value[request.auth.token.email]
            : null));
    }

    function isSuperAdmin() {
      return isIbrahim() 
        || (isSignedIn() && isVerified() && getUserRole() == 'super_admin');
    }

    function isProcessEngineerOrHigher() {
      return isIbrahim()
        || (isSignedIn() && isVerified() && (getUserRole() == 'super_admin' || getUserRole() == 'process_engineer' || getUserRole() == 'line_leader'));
    }

    function isValidAppState(data) {
      return data.keys().hasAll(['key', 'value']) && data.key is string && data.value != null;
    }
  }
}